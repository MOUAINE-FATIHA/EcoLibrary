    "components": {
        "schemas": {
            "Categorie": {
                "required": [
                    "nom"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "nom": {
                        "type": "string",
                        "example": "Roman"
                    },
                    "description": {
                        "type": "string",
                        "example": "Livres de fiction narrative"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "datetime"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "datetime"
                    }
                },
                "type": "object"
            },
            "Livre": {
                "required": [
                    "categorie_id",
                    "titre",
                    "auteur"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "categorie_id": {
                        "type": "integer",
                        "example": 2
                    },
                    "titre": {
                        "type": "string",
                        "example": "Le Petit Prince"
                    },
                    "auteur": {
                        "type": "string",
                        "example": "Antoine de Saint-Exupéry"
                    },
                    "isbn": {
                        "type": "string",
                        "example": "978-2-07-040850-4"
                    },
                    "description": {
                        "type": "string",
                        "example": "Un conte poétique et philosophique"
                    },
                    "total_exemplaires": {
                        "type": "integer",
                        "example": 5
                    },
                    "exemplaires_dispo": {
                        "type": "integer",
                        "example": 3
                    },
                    "exemplaires_degrades": {
                        "type": "integer",
                        "example": 1
                    },
                    "nb_consultations": {
                        "type": "integer",
                        "example": 42
                    },
                    "date_publication": {
                        "type": "string",
                        "format": "date",
                        "example": "1943-04-06"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "datetime"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "datetime"
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "Token",
                "description": "Entrez votre token Sanctum : Bearer {token}"
            }
        }
    },
    "tags": [
        {
            "name": "Administration",
            "description": "Statistiques et rapports (admin uniquement)"
        },
        {
            "name": "Authentification",
            "description": "Inscription, connexion et déconnexion"
        },
        {
            "name": "Catégories",
            "description": "Gestion des catégories de livres"
        },
        {
            "name": "Livres",
            "description": "Gestion des livres de la bibliothèque"
        }
    ],
    "security": [
        {
            "sanctum": []
        }
    ]
}